<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.execute.mapper.RequirementMapper">

    <resultMap type="Requirement" id="RequirementResult">
        <result property="reqId"    column="req_id"    />
        <result property="projectId"    column="project_id"    />
        <result property="projectName"    column="project_name"    />
        <result property="moduleId"    column="module_id"    />
        <result property="moduleName"    column="module_name"    />
        <result property="bookmark"    column="bookmark"    />
        <result property="reqTitle"    column="req_title"    />
        <result property="versionId"    column="version_id"    />
        <result property="description"    column="description"    />
        <result property="priority"    column="priority"    />
        <result property="status"    column="status"    />
        <result property="assignTo"    column="assign_to"    />
        <result property="assignToName"    column="assign_to_name"    />
        <result property="reviewer"    column="reviewer"    />
        <result property="reviewerName"    column="reviewer_name"    />
        <result property="estimateTime"    column="estimate_time"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="delFlag"    column="del_flag"    />
    </resultMap>

    <resultMap id="RequirementTaskResult" type="Requirement" extends="RequirementResult">
        <collection property="taskList" ofType="Task" column="req_id" select="selectTaskList" />
    </resultMap>

    <resultMap type="Task" id="TaskResult">
        <result property="taskId"    column="task_id"    />
        <result property="projectId"    column="project_id"    />
        <result property="reqId"    column="req_id"    />
        <result property="moduleId"    column="module_id"    />
        <result property="taskName"    column="task_name"    />
        <result property="description"    column="description"    />
        <result property="taskType"    column="task_type"    />
        <result property="priority"    column="priority"    />
        <result property="status"    column="status"    />
        <result property="assignTo"    column="assign_to"    />
        <result property="estimateTime"    column="estimate_time"    />
        <result property="consumedTime"    column="consumed_time"    />
        <result property="planStartDate"    column="plan_start_date"    />
        <result property="planEndDate"    column="plan_end_date"    />
        <result property="deadline"    column="deadline"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="delFlag"    column="del_flag"    />
    </resultMap>

    <sql id="selectRequirementVo">
        select r.req_id, r.project_id, p.project_name, r.module_id, pm.module_name, r.bookmark, r.req_title, r.version_id, r.description, r.priority, r.status, r.assign_to, u1.nick_name as assign_to_name, r.reviewer, u2.nick_name as reviewer_name, r.estimate_time, r.create_by, r.create_time, r.update_by, r.update_time, r.del_flag
        from requirement r
        left join project p on r.project_id = p.project_id
        left join project_module pm on r.module_id = pm.module_id
        left join sys_user u1 on r.assign_to = u1.user_id
        left join sys_user u2 on r.reviewer = u2.user_id
    </sql>

    <select id="selectRequirementList" parameterType="Requirement" resultMap="RequirementResult">
        <include refid="selectRequirementVo"/>
        <where>
            <if test="reqId != null "> and r.req_id = #{reqId}</if>
            <if test="projectId != null "> and r.project_id like concat('%', #{projectId}, '%')</if>
            <if test="moduleId != null "> and r.module_id like concat('%', #{moduleId}, '%')</if>
            <if test="bookmark != null  and bookmark != ''"> and r.bookmark = #{bookmark}</if>
            <if test="reqTitle != null  and reqTitle != ''"> and r.req_title like concat('%', #{reqTitle}, '%')</if>
            <if test="versionId != null "> and r.version_id = #{versionId}</if>
            <if test="description != null  and description != ''"> and r.description like concat('%', #{description}, '%')</if>
            <if test="priority != null  and priority != ''"> and r.priority = #{priority}</if>
            <if test="status != null "> and r.status = #{status}</if>
            <if test="assignToNameSearch != null  and assignToNameSearch != ''"> and u1.nick_name like concat('%', #{assignToNameSearch}, '%')</if>
        </where>
    </select>

    <select id="selectRequirementByReqId" parameterType="Long" resultMap="RequirementTaskResult">
        select r.req_id, r.project_id, p.project_name, r.module_id, pm.module_name, r.bookmark, r.req_title, r.version_id, r.description, r.priority, r.status, r.assign_to, u1.nick_name as assign_to_name, r.reviewer, u2.nick_name as reviewer_name, r.estimate_time, r.create_by, r.create_time, r.update_by, r.update_time, r.del_flag
        from requirement r
        left join project p on r.project_id = p.project_id
        left join project_module pm on r.module_id = pm.module_id
        left join sys_user u1 on r.assign_to = u1.user_id
        left join sys_user u2 on r.reviewer = u2.user_id
        where r.req_id = #{reqId}
    </select>

    <select id="selectTaskList" resultMap="TaskResult">
        select task_id, project_id, req_id, module_id, task_name, description, task_type, priority, status, assign_to, estimate_time, consumed_time, plan_start_date, plan_end_date, deadline, create_by, create_time, update_by, update_time, del_flag
        from task
        where req_id = #{req_id}
    </select>

    <insert id="insertRequirement" parameterType="Requirement" useGeneratedKeys="true" keyProperty="reqId">
        insert into requirement
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="projectId != null">project_id,</if>
            <if test="moduleId != null">module_id,</if>
            <if test="bookmark != null">bookmark,</if>
            <if test="reqTitle != null and reqTitle != ''">req_title,</if>
            <if test="versionId != null">version_id,</if>
            <if test="description != null">description,</if>
            <if test="priority != null">priority,</if>
            <if test="status != null">status,</if>
            <if test="assignTo != null">assign_to,</if>
            <if test="reviewer != null">reviewer,</if>
            <if test="estimateTime != null">estimate_time,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="delFlag != null">del_flag,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="projectId != null">#{projectId},</if>
            <if test="moduleId != null">#{moduleId},</if>
            <if test="bookmark != null">#{bookmark},</if>
            <if test="reqTitle != null and reqTitle != ''">#{reqTitle},</if>
            <if test="versionId != null">#{versionId},</if>
            <if test="description != null">#{description},</if>
            <if test="priority != null">#{priority},</if>
            <if test="status != null">#{status},</if>
            <if test="assignTo != null">#{assignTo},</if>
            <if test="reviewer != null">#{reviewer},</if>
            <if test="estimateTime != null">#{estimateTime},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="delFlag != null">#{delFlag},</if>
        </trim>
    </insert>

    <update id="updateRequirement" parameterType="Requirement">
        update requirement
        <trim prefix="SET" suffixOverrides=",">
            <if test="projectId != null">project_id = #{projectId},</if>
            <if test="moduleId != null">module_id = #{moduleId},</if>
            <if test="bookmark != null">bookmark = #{bookmark},</if>
            <if test="reqTitle != null and reqTitle != ''">req_title = #{reqTitle},</if>
            <if test="versionId != null">version_id = #{versionId},</if>
            <if test="description != null">description = #{description},</if>
            <if test="priority != null">priority = #{priority},</if>
            <if test="status != null">status = #{status},</if>
            <if test="assignTo != null">assign_to = #{assignTo},</if>
            <if test="reviewer != null">reviewer = #{reviewer},</if>
            <if test="estimateTime != null">estimate_time = #{estimateTime},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="delFlag != null">del_flag = #{delFlag},</if>
        </trim>
        where req_id = #{reqId}
    </update>

    <delete id="deleteRequirementByReqId" parameterType="Long">
        delete from requirement where req_id = #{reqId}
    </delete>

    <delete id="deleteRequirementByReqIds" parameterType="String">
        delete from requirement where req_id in
        <foreach item="reqId" collection="array" open="(" separator="," close=")">
            #{reqId}
        </foreach>
    </delete>

    <delete id="deleteTaskByReqIds" parameterType="String">
        delete from task where req_id in
        <foreach item="reqId" collection="array" open="(" separator="," close=")">
            #{reqId}
        </foreach>
    </delete>

    <delete id="deleteTaskByReqId" parameterType="Long">
        delete from task where req_id = #{reqId}
    </delete>

    <insert id="batchTask">
        insert into task( task_id, project_id, req_id, module_id, task_name, description, task_type, priority, status, assign_to, estimate_time, consumed_time, plan_start_date, plan_end_date, deadline, create_by, create_time, update_by, update_time, del_flag) values
        <foreach item="item" index="index" collection="list" separator=",">
            ( #{item.taskId}, #{item.projectId}, #{item.reqId}, #{item.moduleId}, #{item.taskName}, #{item.description}, #{item.taskType}, #{item.priority}, #{item.status}, #{item.assignTo}, #{item.estimateTime}, #{item.consumedTime}, #{item.planStartDate}, #{item.planEndDate}, #{item.deadline}, #{item.createBy}, #{item.createTime}, #{item.updateBy}, #{item.updateTime}, #{item.delFlag})
        </foreach>
    </insert>
</mapper>
