<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.execute.mapper.TaskMapper">
    
    <resultMap type="Task" id="TaskResult">
        <result property="taskId"    column="task_id"    />
        <result property="projectId"    column="project_id"    />
        <result property="reqId"    column="req_id"    />
        <result property="moduleId"    column="module_id"    />
        <result property="taskName"    column="task_name"    />
        <result property="description"    column="description"    />
        <result property="taskType"    column="task_type"    />
        <result property="priority"    column="priority"    />
        <result property="status"    column="status"    />
        <result property="assignTo"    column="assign_to"    />
        <result property="assignToName"    column="assign_to_name"    />
        <result property="estimateTime"    column="estimate_time"    />
        <result property="consumedTime"    column="consumed_time"    />
        <result property="planStartDate"    column="plan_start_date"    />
        <result property="planEndDate"    column="plan_end_date"    />
        <result property="deadline"    column="deadline"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="delFlag"    column="del_flag"    />
    </resultMap>

    <resultMap id="TaskWorkLogResult" type="Task" extends="TaskResult">
        <collection property="workLogList" ofType="WorkLog" column="task_id" select="selectWorkLogList" />
    </resultMap>

    <resultMap type="WorkLog" id="WorkLogResult">
        <result property="logId"    column="log_id"    />
        <result property="taskId"    column="task_id"    />
        <result property="userId"    column="user_id"    />
        <result property="workDate"    column="work_date"    />
        <result property="hours"    column="hours"    />
        <result property="description"    column="description"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <sql id="selectTaskVo">
        select t.task_id, t.project_id, t.req_id, t.module_id, t.task_name, t.description, t.task_type, t.priority, t.status, t.assign_to, u.nick_name as assign_to_name, t.estimate_time, t.consumed_time, t.plan_start_date, t.plan_end_date, t.deadline, t.create_by, t.create_time, t.update_by, t.update_time, t.del_flag
        from task t
        left join sys_user u on t.assign_to = u.user_id
    </sql>

    <select id="selectTaskList" parameterType="Task" resultMap="TaskResult">
        <include refid="selectTaskVo"/>
        <where>  
            <if test="projectId != null "> and t.project_id = #{projectId}</if>
            <if test="reqId != null "> and t.req_id = #{reqId}</if>
            <if test="moduleId != null "> and t.module_id = #{moduleId}</if>
            <if test="taskName != null  and taskName != ''"> and t.task_name like concat('%', #{taskName}, '%')</if>
            <if test="description != null  and description != ''"> and t.description = #{description}</if>
            <if test="taskType != null  and taskType != ''"> and t.task_type = #{taskType}</if>
            <if test="priority != null  and priority != ''"> and t.priority = #{priority}</if>
            <if test="status != null "> and t.status = #{status}</if>
            <if test="assignTo != null "> and t.assign_to = #{assignTo}</if>
            <if test="estimateTime != null "> and t.estimate_time = #{estimateTime}</if>
            <if test="consumedTime != null "> and t.consumed_time = #{consumedTime}</if>
            <if test="planStartDate != null "> and t.plan_start_date = #{planStartDate}</if>
            <if test="planEndDate != null "> and t.plan_end_date = #{planEndDate}</if>
            <if test="deadline != null "> and t.deadline = #{deadline}</if>
        </where>
    </select>
    
    <select id="selectTaskByTaskId" parameterType="Long" resultMap="TaskWorkLogResult">
        select t.task_id, t.project_id, t.req_id, t.module_id, t.task_name, t.description, t.task_type, t.priority, t.status, t.assign_to, u.nick_name as assign_to_name, t.estimate_time, t.consumed_time, t.plan_start_date, t.plan_end_date, t.deadline, t.create_by, t.create_time, t.update_by, t.update_time, t.del_flag
        from task t
        left join sys_user u on t.assign_to = u.user_id
        where t.task_id = #{taskId}
    </select>

    <select id="selectWorkLogList" resultMap="WorkLogResult">
        select log_id, task_id, user_id, work_date, hours, description, create_by, create_time, update_by, update_time
        from work_log
        where task_id = #{task_id}
    </select>

    <insert id="insertTask" parameterType="Task" useGeneratedKeys="true" keyProperty="taskId">
        insert into task
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="projectId != null">project_id,</if>
            <if test="reqId != null">req_id,</if>
            <if test="moduleId != null">module_id,</if>
            <if test="taskName != null and taskName != ''">task_name,</if>
            <if test="description != null">description,</if>
            <if test="taskType != null">task_type,</if>
            <if test="priority != null">priority,</if>
            <if test="status != null">status,</if>
            <if test="assignTo != null">assign_to,</if>
            <if test="estimateTime != null">estimate_time,</if>
            <if test="consumedTime != null">consumed_time,</if>
            <if test="planStartDate != null">plan_start_date,</if>
            <if test="planEndDate != null">plan_end_date,</if>
            <if test="deadline != null">deadline,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="delFlag != null">del_flag,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="projectId != null">#{projectId},</if>
            <if test="reqId != null">#{reqId},</if>
            <if test="moduleId != null">#{moduleId},</if>
            <if test="taskName != null and taskName != ''">#{taskName},</if>
            <if test="description != null">#{description},</if>
            <if test="taskType != null">#{taskType},</if>
            <if test="priority != null">#{priority},</if>
            <if test="status != null">#{status},</if>
            <if test="assignTo != null">#{assignTo},</if>
            <if test="estimateTime != null">#{estimateTime},</if>
            <if test="consumedTime != null">#{consumedTime},</if>
            <if test="planStartDate != null">#{planStartDate},</if>
            <if test="planEndDate != null">#{planEndDate},</if>
            <if test="deadline != null">#{deadline},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="delFlag != null">#{delFlag},</if>
         </trim>
    </insert>

    <update id="updateTask" parameterType="Task">
        update task
        <trim prefix="SET" suffixOverrides=",">
            <if test="projectId != null">project_id = #{projectId},</if>
            <if test="reqId != null">req_id = #{reqId},</if>
            <if test="moduleId != null">module_id = #{moduleId},</if>
            <if test="taskName != null and taskName != ''">task_name = #{taskName},</if>
            <if test="description != null">description = #{description},</if>
            <if test="taskType != null">task_type = #{taskType},</if>
            <if test="priority != null">priority = #{priority},</if>
            <if test="status != null">status = #{status},</if>
            <if test="assignTo != null">assign_to = #{assignTo},</if>
            <if test="estimateTime != null">estimate_time = #{estimateTime},</if>
            <if test="consumedTime != null">consumed_time = #{consumedTime},</if>
            <if test="planStartDate != null">plan_start_date = #{planStartDate},</if>
            <if test="planEndDate != null">plan_end_date = #{planEndDate},</if>
            <if test="deadline != null">deadline = #{deadline},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="delFlag != null">del_flag = #{delFlag},</if>
        </trim>
        where task_id = #{taskId}
    </update>

    <delete id="deleteTaskByTaskId" parameterType="Long">
        delete from task where task_id = #{taskId}
    </delete>

    <delete id="deleteTaskByTaskIds" parameterType="String">
        delete from task where task_id in 
        <foreach item="taskId" collection="array" open="(" separator="," close=")">
            #{taskId}
        </foreach>
    </delete>
    
    <delete id="deleteWorkLogByTaskIds" parameterType="String">
        delete from work_log where task_id in 
        <foreach item="taskId" collection="array" open="(" separator="," close=")">
            #{taskId}
        </foreach>
    </delete>

    <delete id="deleteWorkLogByTaskId" parameterType="Long">
        delete from work_log where task_id = #{taskId}
    </delete>

    <insert id="batchWorkLog">
        insert into work_log( log_id, task_id, user_id, work_date, hours, description, create_by, create_time, update_by, update_time) values
        <foreach item="item" index="index" collection="list" separator=",">
            ( #{item.logId}, #{item.taskId}, #{item.userId}, #{item.workDate}, #{item.hours}, #{item.description}, #{item.createBy}, #{item.createTime}, #{item.updateBy}, #{item.updateTime})
        </foreach>
    </insert>
</mapper>